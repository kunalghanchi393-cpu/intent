# ============================================================
# LLM Provider — set at least ONE of these two
# OpenAI: platform.openai.com (paid)
# Groq:   console.groq.com    (free, 14k req/day)
# Agent tries OpenAI first, falls back to Groq automatically.
# ============================================================
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ============================================================
# Tavily — free at tavily.com (1000 searches/month free)
# ============================================================
TAVILY_API_KEY=tvly-...

# ============================================================
# Masumi — already set in Railway, do not change
# ============================================================
AGENT_IDENTIFIER=...
PAYMENT_API_KEY=...
SELLER_VKEY=...
NETWORK=Preprod

# ============================================================
# Optional tuning
# ============================================================
OPENAI_TIMEOUT=60
RESEARCH_TIMEOUT=30
